---
import ProjectCard from "../components/ProjectCard.astro";
import SiteLayout from "../layouts/SiteLayout.astro";
import { decks } from "../data/decks";
---

<SiteLayout>
  <main class="page-shell">
    <section class="intro-grid">
      <div>
        <p class="kicker">Physics Portfolio</p>
        <h1>Presentations, simulations, and animations I want to share.</h1>
      </div>
      <div class="intro-copy">
        <p>
          I am an Applied Physics MSc student at TU Delft with an Electrical Engineering background.
          This is a collection of projects from radiation damage, microscopy, condensed matter,
          computational physics, nanotechnology.
        </p>
        <div class="intro-actions">
          <a class="button primary" href="#presentations">View presentations</a>
          <a class="button ghost" href="/assets/documents/ekvin-saleh-cv.pdf">Open CV</a>
        </div>
      </div>
    </section>

    <section class="section-block" id="presentations">
      <div class="section-heading">
        <div>
          <p class="kicker">Presentations</p>
          <h2>Topics</h2>
        </div>
        <p>
          Presentations and project decks from my studies. A lot of the work here was turning
          mechanisms into figures and animations so the physics could be followed clearly.
        </p>
      </div>
      <div class="project-grid">
        {decks.map((deck) => <ProjectCard deck={deck} />)}
      </div>
    </section>

    <section class="publication-strip">
      <img src="/assets/images/eis-paper-cover.png" alt="" loading="lazy" />
      <div>
        <p class="kicker">Published paper</p>
        <h2>EIS-Based State of Charge Characterization of Electric Double-Layer Capacitors</h2>
        <p>
          IEEE Energy Conversion Congress and Exposition, 2025. From my BSc thesis work on Kelvin
          fixtures, low-frequency EIS measurements, and automated EDLC state-of-charge estimation.
        </p>
        <a class="text-link" href="/publication/">Open publication page</a>
      </div>
    </section>
  </main>
</SiteLayout>
