---
import SiteLayout from "../layouts/SiteLayout.astro";
---

<SiteLayout title="Published Paper">
  <main class="page-shell">
    <a class="back-link" href="/">Back home</a>
    <section class="publication-page">
      <div class="publication-cover">
        <img src="/assets/images/eis-paper-cover.png" alt="First page of the EIS paper" />
      </div>
      <div class="publication-copy">
        <p class="kicker">Published paper</p>
        <h1>EIS-Based State of Charge Characterization of Electric Double-Layer Capacitors</h1>
        <p class="lead">IEEE Energy Conversion Congress and Exposition, 2025</p>
        <p>Ekvin Saleh, Seyedreza Azizighalehsari, Prasanth Venugopal, and Gert Rietveld.</p>
        <a class="button primary" href="/assets/documents/eis-edlc-ieee-ecce-2025.pdf"
          >Open paper PDF</a
        >
      </div>
    </section>
  </main>
</SiteLayout>
