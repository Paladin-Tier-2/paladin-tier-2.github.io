---
import type { Deck } from "../data/decks";
import { slideImage } from "../data/decks";

type Props = {
  deck: Deck;
};

const { deck } = Astro.props;
const slides = deck.slides ?? Array.from({ length: deck.slideCount }, (_, index) => index + 1);
const mediaBySlide = new Map<number, Deck["media"]>();

for (const media of deck.media) {
  const current = mediaBySlide.get(media.slide) ?? [];
  current.push(media);
  mediaBySlide.set(media.slide, current);
}
---

<div class="deck-viewer" data-deck-viewer>
  <div class="deck-frame reveal" tabindex="0">
    <div class="slides">
      {
        slides.map((slideNumber, index) => {
          const embeddedMedia = mediaBySlide.get(slideNumber) ?? [];

          return (
            <section>
              <div class="slide-shell">
                <img
                  class="slide-image"
                  src={slideImage(deck, slideNumber)}
                  alt={`${deck.shortTitle}, slide ${index + 1} of ${slides.length} (original slide ${slideNumber})`}
                  loading={index < 2 ? "eager" : "lazy"}
                />
                {embeddedMedia.map((item) => {
                  const src = `${deck.mediaRoot}/${item.file}`;
                  const isGif = item.file.endsWith(".gif");
                  const style = [
                    `left: ${item.placement.left}%`,
                    `top: ${item.placement.top}%`,
                    `width: ${item.placement.width}%`,
                    `height: ${item.placement.height}%`,
                  ].join("; ");

                  return (
                    <div class="embedded-media" style={style}>
                      {isGif ? (
                        <img src={src} alt={item.label} loading="lazy" />
                      ) : (
                        <video
                          src={src}
                          data-autoplay
                          autoplay
                          muted
                          loop
                          playsinline
                          preload="auto"
                          aria-label={item.label}
                        />
                      )}
                    </div>
                  );
                })}
              </div>
            </section>
          );
        })
      }
    </div>
  </div>
</div>

<script>
  import Reveal from "reveal.js";
  import "reveal.js/reveal.css";

  const viewers = document.querySelectorAll("[data-deck-viewer] .reveal");

  for (const viewer of viewers) {
    if (viewer instanceof HTMLElement && !viewer.dataset.ready) {
      viewer.dataset.ready = "true";
      const deck = new Reveal(viewer, {
        embedded: true,
        controls: false,
        progress: false,
        slideNumber: false,
        hash: false,
        keyboard: true,
        width: 1600,
        height: 900,
        margin: 0.02,
        transition: "none",
        backgroundTransition: "none",
      });
      (viewer as HTMLElement & { deck?: unknown }).deck = deck;

      let initialized = false;

      const relayout = () => {
        if (!initialized) return;

        deck.layout();
      };

      const syncVideo = () => {
        viewer.querySelectorAll("section:not(.present) video").forEach((video) => {
          if (video instanceof HTMLVideoElement) {
            video.pause();
          }
        });

        viewer.querySelectorAll(".present video").forEach((video) => {
          if (video instanceof HTMLVideoElement) {
            video.currentTime = 0;
            video.muted = true;
            video.play().catch(() => {
              video.controls = true;
            });
          }
        });
      };

      deck.on("ready", () => {
        initialized = true;
        syncVideo();
        relayout();
        requestAnimationFrame(relayout);
      });
      deck.on("slidechanged", syncVideo);
      Promise.resolve(deck.initialize()).then(() => {
        initialized = true;
        relayout();
        requestAnimationFrame(relayout);
      });
      window.addEventListener("resize", relayout);
      window.addEventListener("orientationchange", relayout);
      viewer.focus({ preventScroll: true });
    }
  }
</script>
